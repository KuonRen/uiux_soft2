@if (!string.IsNullOrEmpty(ImageUrl)) {
    <div class="image-lightbox-backdrop" @onclick="OnClose">
        <div class="image-lightbox-content"
             tabindex="-1"
             @ref="contentElement"
             @onkeydown="HandleKeyDown"
             @onclick:stopPropagation>
            <img src="@ImageUrl" alt="拡大画像プレビュー" />
            <button class="image-lightbox-close" type="button" @onclick="OnClose" aria-label="プレビューを閉じる">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private ElementReference contentElement;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            await contentElement.FocusAsync();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs args) {
        if (args.Key == "Escape") {
            await OnClose.InvokeAsync();
        }
    }
}
