@page "/not-found"
@layout MainLayout

<PageTitle>ページが見つかりません</PageTitle>

<main class="page-container">
    <section class="page-hero" aria-labelledby="not-found-title">
        <p class="page-kicker">Not Found</p>

        <h1 id="not-found-title">
            ページが見つかりません
        </h1>

        <p class="page-lead">
            指定された記事またはページは存在しません。トップページから記事を選び直してください。
        </p>

        <p>
            <a href="">トップページへ戻る</a>
        </p>
    </section>
</main>
