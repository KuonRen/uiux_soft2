@if (Topic is not null && Article is not null) {
    <div class="topic-modal-backdrop" @onclick="OnClose">
        <section class="topic-modal"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="topic-modal-title"
                 @onclick:stopPropagation>

            <div class="topic-modal-header">
                <div>
                    <p class="topic-modal-kicker">Selected Topic</p>

                    <h2 id="topic-modal-title">
                        <span class="topic-modal-icon" aria-hidden="true">
                            <TopicIcon IconType="@Topic.IconType" Size="20" StrokeWidth="2.5" />
                        </span>
                        <span>@Topic.Title</span>
                    </h2>
                </div>

                <button class="topic-modal-close"
                        type="button"
                        @onclick="OnClose"
                        aria-label="モーダルを閉じる">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <div class="topic-modal-body">
                <div class="topic-article-list" aria-label="記事一覧">
                    @foreach (var article in Topic.Articles) {
                        <button class="@GetArticleButtonClass(article)"
                                type="button"
                                @onclick="() => OnSelectArticle.InvokeAsync(article)">
                            @article.Title
                        </button>
                    }
                </div>

                <div class="topic-article-content">
                    <article @key="Article">
                        <h3>@Article.Title</h3>
                        @if (!string.IsNullOrEmpty(Article.ImagePath)) {
                            <button class="topic-article-image-container"
                                    type="button"
                                    @onclick="() => OnPreviewImage.InvokeAsync(Article.ImagePath)"
                                    aria-label="画像を拡大表示">
                                <img src="@Article.ImagePath" alt="@Article.Title" onerror="this.style.display='none'" />
                                <span class="image-zoom-badge" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8"></circle>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                        <line x1="11" y1="8" x2="11" y2="14"></line>
                                        <line x1="8" y1="11" x2="14" y2="11"></line>
                                    </svg>
                                </span>
                            </button>
                        }
                        <p>@Article.Body</p>
                    </article>
                </div>
            </div>

            <div class="topic-modal-footer">
                <button class="topic-article-copy-link"
                        type="button"
                        @onclick="() => OnCopyArticleLink.InvokeAsync(Article)">
                    @CopyLinkLabel
                </button>

                <span class="copy-status" aria-live="polite">@CopyLinkLabel</span>
            </div>
        </section>
    </div>
}

@code {
    [Parameter]
    public TopicItem? Topic { get; set; }

    [Parameter]
    public TopicArticle? Article { get; set; }

    [Parameter]
    public string CopyLinkLabel { get; set; } = "この記事のリンクをコピー";

    [Parameter]
    public EventCallback<TopicArticle> OnSelectArticle { get; set; }

    [Parameter]
    public EventCallback<string> OnPreviewImage { get; set; }

    [Parameter]
    public EventCallback<TopicArticle> OnCopyArticleLink { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string GetArticleButtonClass(TopicArticle article) {
        return Article == article
            ? "topic-article-button is-selected"
            : "topic-article-button";
    }
}
