@if (IsLoading) {
    <section class="topic-status" aria-live="polite">
        <p>記事データを読み込んでいます。</p>
    </section>
} else if (!string.IsNullOrEmpty(ErrorMessage)) {
    <section class="topic-status topic-status-error" role="alert">
        <h2>記事データを読み込めませんでした</h2>
        <p>@ErrorMessage</p>
        <button type="button" @onclick="OnReload">
            再読み込み
        </button>
    </section>
}

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback OnReload { get; set; }
}
