@page "/"
@rendermode InteractiveServer
@using uiux.Models
@using uiux.Services
@inject OsakaDataService DataService
@inject IJSRuntime JSRuntime

<PageTitle>大阪紹介</PageTitle>

<section class="page-container">

    <section class="page-hero" aria-labelledby="page-title">
        <p class="page-kicker">UI / UX Assignment</p>

        <h1 id="page-title">
            大阪を3つの視点からの紹介
        </h1>

        <p class="page-lead">
            観光地・歴史・建築物の3つの切り口から、大阪の特徴を短い記事として紹介します。
        </p>
    </section>

    <div id="topics" class="topic-grid" aria-label="大阪を知る3つの項目">
        @foreach (var topic in topics) {
            <button class="topic-card @topic.GradientClass"
                    type="button"
                    @onclick="() => OpenModal(topic)"
                    aria-label="@($"{topic.Title}の詳細を開く")">

                <div class="topic-card-icon" aria-hidden="true">
                    @if (topic.IconType == "spots") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                        </svg>
                    } else if (topic.IconType == "history") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                            <path d="M6 6h10"></path>
                            <path d="M6 10h10"></path>
                        </svg>
                    } else if (topic.IconType == "architecture") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
                            <line x1="9" y1="22" x2="9" y2="16"></line>
                            <line x1="15" y1="22" x2="15" y2="16"></line>
                            <line x1="9" y1="16" x2="15" y2="16"></line>
                            <path d="M8 6h.01"></path>
                            <path d="M16 6h.01"></path>
                            <path d="M8 10h.01"></path>
                            <path d="M16 10h.01"></path>
                        </svg>
                    }
                </div>

                <span class="topic-card-index">
                    @topic.IndexLabel
                </span>

                <span class="topic-card-title">
                    @topic.Title
                </span>

                <span class="topic-card-description">
                    @topic.Description
                </span>

                <span class="topic-card-footer">
                    <span>@topic.Articles.Count 件の記事</span>
                    <span>詳しく見る →</span>
                </span>
            </button>
        }
    </div>

    @if (isModalOpen && selectedTopic is not null && selectedArticle is not null) {
        <div class="topic-modal-backdrop" @onclick="CloseModal">
            <section class="topic-modal"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="topic-modal-title"
                     @onclick:stopPropagation>

                <div class="topic-modal-header">
                    <div>
                        <p class="topic-modal-kicker">Selected Topic</p>

                        <h2 id="topic-modal-title">
                            <span class="topic-modal-icon me-2" aria-hidden="true">
                                @if (selectedTopic.IconType == "spots") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                                    </svg>
                                } else if (selectedTopic.IconType == "history") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                                        <path d="M6 6h10"></path>
                                        <path d="M6 10h10"></path>
                                    </svg>
                                } else if (selectedTopic.IconType == "architecture") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
                                        <line x1="9" y1="22" x2="9" y2="16"></line>
                                        <line x1="15" y1="22" x2="15" y2="16"></line>
                                        <line x1="9" y1="16" x2="15" y2="16"></line>
                                        <path d="M8 6h.01"></path>
                                        <path d="M16 6h.01"></path>
                                        <path d="M8 10h.01"></path>
                                        <path d="M16 10h.01"></path>
                                    </svg>
                                }
                            </span>
                            <span>@selectedTopic.Title</span>
                        </h2>
                    </div>

                    <button class="topic-modal-close"
                            type="button"
                            @onclick="CloseModal"
                            aria-label="モーダルを閉じる">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>

                <div class="topic-modal-body">

                    <div class="topic-article-list" aria-label="記事一覧">
                        @foreach (var article in selectedTopic.Articles) {
                            <button class="@GetArticleButtonClass(article)"
                                    type="button"
                                    @onclick="() => SelectArticle(article)">
                                @article.Title
                            </button>
                        }
                    </div>

                    <div class="topic-article-content">
                        @* @key を設定することで、記事が切り替わったときに要素が再構築され、CSSアニメーションが再トリガーされます *@
                        <article @key="selectedArticle">
                            <h3>@selectedArticle.Title</h3>
                            @if (!string.IsNullOrEmpty(selectedArticle.ImagePath)) {
                                <div class="topic-article-image-container">
                                    <img src="@selectedArticle.ImagePath" alt="@selectedArticle.Title" onerror="this.style.display='none'" />
                                </div>
                            }
                            <p>@selectedArticle.Body</p>
                        </article>
                    </div>

                </div>

                <div class="topic-modal-footer">
                    <button type="button" @onclick="CloseModal">
                        閉じる
                    </button>
                </div>

            </section>
        </div>
    }

</section>

@code {
    private List<TopicItem> topics = new();
    private TopicItem? selectedTopic;
    private TopicArticle? selectedArticle;
    private bool isModalOpen;
    private bool _shouldSetupTrap;

    protected override void OnInitialized() {
        topics = DataService.GetTopics();
    }

    // カードクリック時にモーダルを開く
    private void OpenModal(TopicItem topic) {
        selectedTopic = topic;
        selectedArticle = topic.Articles.FirstOrDefault();
        isModalOpen = true;
        _shouldSetupTrap = true; // 次のレンダリングでフォーカストラップを実行するフラグ
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (_shouldSetupTrap && isModalOpen) {
            _shouldSetupTrap = false;
            // BlazorのDOMレンダリングが完了した後に、JSで確実にフォーカストラップをセットアップする
            await JSRuntime.InvokeVoidAsync("window.appModal.setupFocusTrap", ".topic-modal");
        }
    }

    // 記事ボタンクリック時に本文を切り替える
    private void SelectArticle(TopicArticle article) {
        selectedArticle = article;
    }

    // モーダルを閉じて選択状態をリセットする
    private async Task CloseModal() {
        // フォーカストラップを解除
        await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".topic-modal");
        
        isModalOpen = false;
        selectedTopic = null;
        selectedArticle = null;
    }

    // 選択中の記事ボタンだけ見た目を変える
    private string GetArticleButtonClass(TopicArticle article) {
        return selectedArticle == article
            ? "topic-article-button is-selected"
            : "topic-article-button";
    }
}