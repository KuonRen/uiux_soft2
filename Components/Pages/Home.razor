@page "/"
@page "/article/{ArticleId}"
@using uiux_soft2.Models
@using uiux_soft2.Services
@implements IDisposable
@inject OsakaDataService DataService
@inject FavoriteArticleService FavoriteService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>大阪紹介</PageTitle>

<section class="page-container">

    <TopicHero CurrentItem="currentHeroItem"
               NextItem="nextHeroItem"
               OnOpenArticle="NavigateToArticle"
               OnNextImageLoaded="ShowNextHeroImage" />

    @if (isLoadingTopics) {
        <TopicStatus IsLoading="true" />
    } else if (!string.IsNullOrEmpty(loadErrorMessage)) {
        <TopicStatus ErrorMessage="@loadErrorMessage"
                     OnReload="LoadTopicsAsync" />
    } else {
        <TopicGrid Topics="topics"
                   OnOpenTopic="OpenModal" />
    }

    @if (isModalOpen && selectedTopic is not null && selectedArticle is not null) {
        <ArticleModal Topic="selectedTopic"
                      Article="selectedArticle"
                      IsFavorite="@FavoriteService.IsFavorite(selectedArticle.Id)"
                      CopyLinkLabel="@GetCopyLinkLabel(selectedArticle)"
                      CopyLinkHref="@GetArticleHref(selectedArticle)"
                      OnSelectArticle="SelectArticle"
                      OnPreviewImage="PreviewImage"
                      OnCopyArticleLink="CopyArticleLinkAsync"
                      OnToggleFavorite="ToggleFavorite"
                      OnClose="CloseModal" />
    }

    @if (!string.IsNullOrEmpty(previewImageUrl)) {
        <ImageLightbox ImageUrl="@previewImageUrl"
                       OnClose="ClosePreview" />
    }

</section>

@code {
    [Parameter]
    public string? ArticleId { get; set; }

    [SupplyParameterFromQuery(Name = "article")]
    public string? QueryArticleId { get; set; }

    private List<TopicItem> topics = new();
    private TopicItem? selectedTopic;
    private TopicArticle? selectedArticle;
    private bool isModalOpen;
    private bool _shouldSetupTrap;
    private bool _shouldRemoveTrap;
    private bool isLoadingTopics = true;
    private string? previewImageUrl;
    private string? loadErrorMessage;
    private string? copiedArticleId;
    private string? copyErrorArticleId;
    private List<HeroImageItem> heroItems = new();
    private HeroImageItem? currentHeroItem;
    private HeroImageItem? nextHeroItem;
    private readonly Random random = new();
    private CancellationTokenSource? heroRotationCancellation;
    private bool didRestoreFavorites;

    protected override async Task OnInitializedAsync() {
        FavoriteService.ModalVisibilityChanged += HandleFavoriteModalVisibilityChanged;
        await LoadTopicsAsync();
    }

    private async Task LoadTopicsAsync() {
        isLoadingTopics = true;
        loadErrorMessage = null;
        StopHeroRotation();
        ResetModalState();

        try {
            topics = await DataService.GetTopicsAsync();
        } catch {
            topics = new List<TopicItem>();
            heroItems = new List<HeroImageItem>();
            currentHeroItem = null;
            nextHeroItem = null;
            loadErrorMessage = "通信状態を確認して、もう一度読み込んでください。";
            isLoadingTopics = false;
            return;
        }

        NormalizeArticleImagePaths();

        heroItems = topics
            .SelectMany(topic => topic.Articles
                .Where(article => !string.IsNullOrWhiteSpace(article.ImagePath))
                .Select(article => new HeroImageItem(topic, article)))
            .ToList();
        FavoriteService.RegisterTopics(topics);
        currentHeroItem = GetNextHeroItem();

        if (heroItems.Count > 1) {
            heroRotationCancellation = new CancellationTokenSource();
            _ = RotateHeroImagesAsync(heroRotationCancellation.Token);
        }

        HandleArticleRoute();
        isLoadingTopics = false;
    }

    protected override void OnParametersSet() {
        if (topics.Count == 0) {
            return;
        }

        HandleArticleRoute();
    }

    private void HandleArticleRoute() {
        var activeArticleId = GetActiveArticleId();

        if (string.IsNullOrWhiteSpace(activeArticleId)) {
            if (isModalOpen) {
                ResetModalState();
                _shouldRemoveTrap = true;
            }

            return;
        }

        if (!OpenArticleById(activeArticleId)) {
            NavigateToNotFound();
        }
    }

    // カードクリック時にモーダルを開く
    private void OpenModal(TopicItem topic) {
        var firstArticle = topic.Articles.FirstOrDefault();
        if (firstArticle is not null) {
            NavigateToArticle(firstArticle);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender && !didRestoreFavorites) {
            didRestoreFavorites = true;
            var favoriteIds = await JSRuntime.InvokeAsync<string[]>("window.appFavorites.get");
            FavoriteService.RestoreFavorites(favoriteIds);
        }

        if (_shouldRemoveTrap) {
            _shouldRemoveTrap = false;
            await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".topic-modal");
        }

        if (_shouldSetupTrap && isModalOpen) {
            _shouldSetupTrap = false;
            // BlazorのDOMレンダリングが完了した後に、JSで確実にフォーカストラップをセットアップする
            await JSRuntime.InvokeVoidAsync("window.appModal.setupFocusTrap", ".topic-modal");
        }

    }

    // 記事ボタンクリック時に本文を切り替える
    private void SelectArticle(TopicArticle article) {
        copiedArticleId = null;
        copyErrorArticleId = null;
        NavigateToArticle(article);
    }

    // モーダルを閉じて選択状態をリセットする
    private async Task CloseModal() {
        // フォーカストラップを解除
        await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".topic-modal");
        ResetModalState();
        NavigationManager.NavigateTo(NavigationManager.BaseUri);
    }

    // プレビュー表示
    private void PreviewImage(string url) {
        previewImageUrl = url;
    }

    // プレビューを閉じる
    private void ClosePreview() {
        previewImageUrl = null;
    }

    private async Task CopyArticleLinkAsync(TopicArticle article) {
        try {
            var articleHref = GetArticleHref(article);
            var preparedCopyResult = await JSRuntime.InvokeAsync<bool?>("window.appClipboard.getPreparedResult", articleHref);
            var copied = preparedCopyResult ?? await JSRuntime.InvokeAsync<bool>("window.appClipboard.copyText", articleHref);

            copiedArticleId = copied ? article.Id : null;
            copyErrorArticleId = copied ? null : article.Id;
        } catch (JSException) {
            copiedArticleId = null;
            copyErrorArticleId = article.Id;
        }
    }

    private async Task ToggleFavorite(TopicArticle article) {
        if (selectedTopic is not null) {
            FavoriteService.ToggleFavorite(selectedTopic, article);
            await JSRuntime.InvokeVoidAsync("window.appFavorites.set", FavoriteService.GetFavoriteIds());
        }
    }

    private string GetCopyLinkLabel(TopicArticle article) {
        if (copiedArticleId == article.Id) {
            return "コピーしました";
        }

        if (copyErrorArticleId == article.Id) {
            return "コピーできませんでした";
        }

        return "この記事のリンクをコピー";
    }

    private void NavigateToArticle(TopicArticle article) {
        NavigationManager.NavigateTo(GetArticleHref(article));
    }

    private string GetArticleHref(TopicArticle article) {
        return $"{NavigationManager.BaseUri}?article={Uri.EscapeDataString(article.Id)}";
    }

    private string? GetActiveArticleId() {
        return !string.IsNullOrWhiteSpace(QueryArticleId)
            ? QueryArticleId
            : ArticleId;
    }

    private void NormalizeArticleImagePaths() {
        foreach (var article in topics.SelectMany(topic => topic.Articles)) {
            if (string.IsNullOrWhiteSpace(article.ImagePath) || Uri.IsWellFormedUriString(article.ImagePath, UriKind.Absolute)) {
                continue;
            }

            var relativePath = article.ImagePath.TrimStart('/');
            article.ImagePath = NavigationManager.ToAbsoluteUri(relativePath).ToString();
        }
    }

    private bool OpenArticleById(string articleId) {
        foreach (var topic in topics) {
            var article = topic.Articles.FirstOrDefault(article =>
                string.Equals(article.Id, articleId, StringComparison.OrdinalIgnoreCase));

            if (article is null) {
                continue;
            }

            selectedTopic = topic;
            selectedArticle = article;
            previewImageUrl = null;
            copiedArticleId = null;
            copyErrorArticleId = null;

            if (!isModalOpen) {
                isModalOpen = true;
                _shouldSetupTrap = true;
            }

            return true;
        }

        ResetModalState();
        return false;
    }

    private void NavigateToNotFound() {
        NavigationManager.NavigateTo($"{NavigationManager.BaseUri}not-found", replace: true);
    }

    private void ResetModalState() {
        isModalOpen = false;
        selectedTopic = null;
        selectedArticle = null;
        previewImageUrl = null;
        copiedArticleId = null;
        copyErrorArticleId = null;
    }

    private HeroImageItem? GetNextHeroItem() {
        if (heroItems.Count == 0) {
            return null;
        }

        if (heroItems.Count == 1) {
            return heroItems[0];
        }

        HeroImageItem nextItem;
        do {
            nextItem = heroItems[random.Next(heroItems.Count)];
        } while (nextItem == currentHeroItem || nextItem == nextHeroItem);

        return nextItem;
    }

    private async Task RotateHeroImagesAsync(CancellationToken cancellationToken) {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));

        try {
            while (await timer.WaitForNextTickAsync(cancellationToken)) {
                if (FavoriteService.IsFavoriteModalOpen) {
                    continue;
                }

                nextHeroItem = GetNextHeroItem();
                await InvokeAsync(StateHasChanged);
            }
        } catch (OperationCanceledException) {
        }
    }

    private void ShowNextHeroImage() {
        if (nextHeroItem is null) {
            return;
        }

        currentHeroItem = nextHeroItem;
        nextHeroItem = null;
    }

    public void Dispose() {
        FavoriteService.ModalVisibilityChanged -= HandleFavoriteModalVisibilityChanged;
        StopHeroRotation();
    }

    private void HandleFavoriteModalVisibilityChanged() {
        if (FavoriteService.IsFavoriteModalOpen) {
            nextHeroItem = null;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void StopHeroRotation() {
        heroRotationCancellation?.Cancel();
        heroRotationCancellation?.Dispose();
        heroRotationCancellation = null;
    }
}
