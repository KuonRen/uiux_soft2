@page "/"
@page "/article/{ArticleId}"
@using uiux_soft2.Models
@using uiux_soft2.Services
@implements IDisposable
@inject OsakaDataService DataService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>大阪紹介</PageTitle>

<section class="page-container">

    <div class="home-hero-layout">
        <section class="page-hero" aria-labelledby="page-title">
            <p class="page-kicker">guide site</p>

            <h1 id="page-title">
                大阪を3つの視点から紹介
            </h1>

            <p class="page-lead">
                観光地・歴史・食べ物の3つの視点から、大阪の特徴を短い記事として紹介します。
            </p>
        </section>

        @if (currentHeroItem is not null) {
            <button class="topic-hero"
                    type="button"
                    @onclick="() => OpenHeroArticle(currentHeroItem)"
                    aria-label="@($"{currentHeroItem.Article.Title}の記事を開く")">
                <img class="topic-hero-image is-active"
                     src="@currentHeroItem.Article.ImagePath"
                     alt="@currentHeroItem.Article.Title"
                     onerror="this.style.display='none'" />

                @if (nextHeroItem is not null) {
                    <img @key="nextHeroItem.Article.ImagePath"
                         class="topic-hero-image is-next"
                         src="@nextHeroItem.Article.ImagePath"
                         alt=""
                         @onload="ShowNextHeroImage"
                         onerror="this.style.display='none'" />
                }

                <div class="topic-hero-caption">
                    <span>Topic Image</span>
                    <strong>@currentHeroItem.Article.Title</strong>
                    <em>@currentHeroItem.Topic.Title</em>
                </div>
            </button>
        }
    </div>

    <div id="topics" class="topic-grid" aria-label="大阪を知る3つの項目">
        @foreach (var topic in topics) {
            <button class="topic-card @topic.GradientClass"
                    type="button"
                    @onclick="() => OpenModal(topic)"
                    aria-label="@($"{topic.Title}の詳細を開く")">

                <div class="topic-card-icon" aria-hidden="true">
                    @if (topic.IconType == "spots") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                        </svg>
                    } else if (topic.IconType == "history") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                            <path d="M6 6h10"></path>
                            <path d="M6 10h10"></path>
                        </svg>
                    } else if (topic.IconType == "food") {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path>
                            <path d="M7 2v20"></path>
                            <path d="M21 15V2v0a5 5 0 0 0-5 5v8c0 1.1.9 2 2 2h3Z"></path>
                            <path d="M19 17v5"></path>
                        </svg>
                    }
                </div>

                <span class="topic-card-index">
                    @topic.IndexLabel
                </span>

                <span class="topic-card-title">
                    @topic.Title
                </span>

                <span class="topic-card-description">
                    @topic.Description
                </span>

                <span class="topic-card-footer">
                    <span>@topic.Articles.Count 件の記事</span>
                    <span>詳しく見る →</span>
                </span>
            </button>
        }
    </div>

    @if (isModalOpen && selectedTopic is not null && selectedArticle is not null) {
        <div class="topic-modal-backdrop" @onclick="CloseModal">
            <section class="topic-modal"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="topic-modal-title"
                     @onclick:stopPropagation>

                <div class="topic-modal-header">
                    <div>
                        <p class="topic-modal-kicker">Selected Topic</p>

                        <h2 id="topic-modal-title">
                            <span class="topic-modal-icon" aria-hidden="true">
                                @if (selectedTopic.IconType == "spots") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                                    </svg>
                                } else if (selectedTopic.IconType == "history") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
                                        <path d="M6 6h10"></path>
                                        <path d="M6 10h10"></path>
                                    </svg>
                                } else if (selectedTopic.IconType == "food") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path>
                                        <path d="M7 2v20"></path>
                                        <path d="M21 15V2v0a5 5 0 0 0-5 5v8c0 1.1.9 2 2 2h3Z"></path>
                                        <path d="M19 17v5"></path>
                                    </svg>
                                }
                            </span>
                            <span>@selectedTopic.Title</span>
                        </h2>
                    </div>

                    <button class="topic-modal-close"
                            type="button"
                            @onclick="CloseModal"
                            aria-label="モーダルを閉じる">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>

                <div class="topic-modal-body">

                    <div class="topic-article-list" aria-label="記事一覧">
                        @foreach (var article in selectedTopic.Articles) {
                            <button class="@GetArticleButtonClass(article)"
                                    type="button"
                                    @onclick="() => SelectArticle(article)">
                                @article.Title
                            </button>
                        }
                    </div>

                    <div class="topic-article-content">
                        @* @key を設定することで、記事が切り替わったときに要素が再構築され、CSSアニメーションが再トリガーされます *@
                        <article @key="selectedArticle">
                            <h3>@selectedArticle.Title</h3>
                            @if (!string.IsNullOrEmpty(selectedArticle.ImagePath)) {
                                <button class="topic-article-image-container"
                                        type="button"
                                        @onclick="() => PreviewImage(selectedArticle.ImagePath)"
                                        aria-label="画像を拡大表示">
                                    <img src="@selectedArticle.ImagePath" alt="@selectedArticle.Title" onerror="this.style.display='none'" />
                                    <span class="image-zoom-badge" aria-hidden="true">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="11" cy="11" r="8"></circle>
                                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                            <line x1="11" y1="8" x2="11" y2="14"></line>
                                            <line x1="8" y1="11" x2="14" y2="11"></line>
                                        </svg>
                                    </span>
                                </button>
                            }
                            <p>@selectedArticle.Body</p>
                        </article>
                    </div>

                </div>

                <div class="topic-modal-footer">
                    <a class="topic-article-direct-link"
                       href="@GetArticleHref(selectedArticle)">
                        この記事のリンク
                    </a>

                    <button type="button" @onclick="CloseModal">
                        閉じる
                    </button>
                </div>

            </section>
        </div>
    }

    @if (!string.IsNullOrEmpty(previewImageUrl)) {
        <div class="image-lightbox-backdrop" @onclick="ClosePreview">
            <div class="image-lightbox-content" @onclick:stopPropagation>
                <img src="@previewImageUrl" alt="拡大画像プレビュー" />
                <button class="image-lightbox-close" type="button" @onclick="ClosePreview" aria-label="プレビューを閉じる">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>
    }

</section>

@code {
    [Parameter]
    public string? ArticleId { get; set; }

    private List<TopicItem> topics = new();
    private TopicItem? selectedTopic;
    private TopicArticle? selectedArticle;
    private bool isModalOpen;
    private bool _shouldSetupTrap;
    private bool _shouldRemoveTrap;
    private string? previewImageUrl;
    private List<HeroImageItem> heroItems = new();
    private HeroImageItem? currentHeroItem;
    private HeroImageItem? nextHeroItem;
    private readonly Random random = new();
    private CancellationTokenSource? heroRotationCancellation;

    protected override void OnInitialized() {
        topics = DataService.GetTopics();
        heroItems = topics
            .SelectMany(topic => topic.Articles
                .Where(article => !string.IsNullOrWhiteSpace(article.ImagePath))
                .Select(article => new HeroImageItem(topic, article)))
            .ToList();
        currentHeroItem = GetNextHeroItem();

        if (heroItems.Count > 1) {
            heroRotationCancellation = new CancellationTokenSource();
            _ = RotateHeroImagesAsync(heroRotationCancellation.Token);
        }

        if (!string.IsNullOrWhiteSpace(ArticleId)) {
            OpenArticleById(ArticleId);
        }
    }

    protected override void OnParametersSet() {
        if (topics.Count == 0) {
            return;
        }

        if (string.IsNullOrWhiteSpace(ArticleId)) {
            if (isModalOpen) {
                ResetModalState();
                _shouldRemoveTrap = true;
            }

            return;
        }

        OpenArticleById(ArticleId);
    }

    // カードクリック時にモーダルを開く
    private void OpenModal(TopicItem topic) {
        var firstArticle = topic.Articles.FirstOrDefault();
        if (firstArticle is not null) {
            NavigateToArticle(firstArticle);
        }
    }

    private void OpenHeroArticle(HeroImageItem item) {
        NavigateToArticle(item.Article);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (_shouldRemoveTrap) {
            _shouldRemoveTrap = false;
            await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".topic-modal");
        }

        if (_shouldSetupTrap && isModalOpen) {
            _shouldSetupTrap = false;
            // BlazorのDOMレンダリングが完了した後に、JSで確実にフォーカストラップをセットアップする
            await JSRuntime.InvokeVoidAsync("window.appModal.setupFocusTrap", ".topic-modal");
        }
    }

    // 記事ボタンクリック時に本文を切り替える
    private void SelectArticle(TopicArticle article) {
        NavigateToArticle(article);
    }

    // モーダルを閉じて選択状態をリセットする
    private async Task CloseModal() {
        // フォーカストラップを解除
        await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".topic-modal");
        ResetModalState();
        NavigationManager.NavigateTo(NavigationManager.BaseUri);
    }

    // プレビュー表示
    private void PreviewImage(string url) {
        previewImageUrl = url;
    }

    // プレビューを閉じる
    private void ClosePreview() {
        previewImageUrl = null;
    }

    // 選択中の記事ボタンだけ見た目を変える
    private string GetArticleButtonClass(TopicArticle article) {
        return selectedArticle == article
            ? "topic-article-button is-selected"
            : "topic-article-button";
    }

    private void NavigateToArticle(TopicArticle article) {
        NavigationManager.NavigateTo(GetArticleHref(article));
    }

    private string GetArticleHref(TopicArticle article) {
        return $"{NavigationManager.BaseUri}article/{article.Id}";
    }

    private void OpenArticleById(string articleId) {
        foreach (var topic in topics) {
            var article = topic.Articles.FirstOrDefault(article =>
                string.Equals(article.Id, articleId, StringComparison.OrdinalIgnoreCase));

            if (article is null) {
                continue;
            }

            selectedTopic = topic;
            selectedArticle = article;
            previewImageUrl = null;

            if (!isModalOpen) {
                isModalOpen = true;
                _shouldSetupTrap = true;
            }

            return;
        }

        ResetModalState();
    }

    private void ResetModalState() {
        isModalOpen = false;
        selectedTopic = null;
        selectedArticle = null;
        previewImageUrl = null;
    }

    private HeroImageItem? GetNextHeroItem() {
        if (heroItems.Count == 0) {
            return null;
        }

        if (heroItems.Count == 1) {
            return heroItems[0];
        }

        HeroImageItem nextItem;
        do {
            nextItem = heroItems[random.Next(heroItems.Count)];
        } while (nextItem == currentHeroItem || nextItem == nextHeroItem);

        return nextItem;
    }

    private async Task RotateHeroImagesAsync(CancellationToken cancellationToken) {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));

        try {
            while (await timer.WaitForNextTickAsync(cancellationToken)) {
                nextHeroItem = GetNextHeroItem();
                await InvokeAsync(StateHasChanged);
            }
        } catch (OperationCanceledException) {
        }
    }

    private void ShowNextHeroImage() {
        if (nextHeroItem is null) {
            return;
        }

        currentHeroItem = nextHeroItem;
        nextHeroItem = null;
    }

    public void Dispose() {
        heroRotationCancellation?.Cancel();
        heroRotationCancellation?.Dispose();
    }

    private sealed record HeroImageItem(TopicItem Topic, TopicArticle Article);
}
