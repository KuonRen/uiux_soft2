@page "/5ecr3t"
@layout MainLayout
@implements IDisposable
@using System.Globalization
@using uiux_soft2.Services
@inject FavoriteArticleService FavoriteService
@inject NavigationManager NavigationManager

<PageTitle>Hidden Invaders</PageTitle>

@if (hasAccess) {
    <main class="secret-page">
        <section class="secret-shell" aria-labelledby="secret-title">
            <div class="secret-header">
                <div>
                    <p class="secret-kicker">Hidden Route</p>
                    <h1 id="secret-title">Hidden Invaders</h1>
                </div>

                <a class="secret-link" href="">Exit</a>
            </div>

            <div class="game-hud" aria-live="polite">
                <span>Score @score</span>
                <span>@statusText</span>
                <span>Wave @currentWave/@MaxWave</span>
            </div>

            <div class="game-board"
                 @ref="gameBoardElement"
                 tabindex="0"
                 role="application"
                 aria-label="Hidden Invaders"
                 @onkeydown="HandleKeyDown"
                 @onkeyup="HandleKeyUp"
                 @onkeydown:preventDefault="true"
                 @onkeyup:preventDefault="true">
                <div class="scanline" aria-hidden="true"></div>

                @foreach (var enemy in enemies) {
                    <div class="enemy"
                         style="@GetSpriteStyle(enemy.X, enemy.Y)"
                         aria-hidden="true">
                    </div>
                }

                @foreach (var bullet in bullets) {
                    <div class="bullet"
                         style="@GetSpriteStyle(bullet.X, bullet.Y)"
                         aria-hidden="true">
                    </div>
                }

                <div class="player"
                     style="@GetSpriteStyle(playerX, PlayerY)"
                     aria-hidden="true">
                </div>

                @if (gameState is GameState.Ready or GameState.WaveClear or GameState.Win or GameState.GameOver) {
                    <div class="game-message">
                        <strong>@GetMessageTitle()</strong>
                        <span>@GetMessageCopy()</span>
                    </div>
                }
            </div>

            <div class="game-controls" aria-label="操作">
                <span>← → Move</span>
                <span>@GetPrimaryControlHint()</span>
                <span>R Restart</span>
            </div>
        </section>
    </main>
}

@code {
    private const double BoardWidth = 640;
    private const double BoardHeight = 420;
    private const double PlayerWidth = 42;
    private const double PlayerY = 370;
    private const double EnemySize = 28;
    private const double BulletWidth = 4;
    private const double BulletHeight = 14;
    private const double PlayerSpeed = 8;
    private const double BulletSpeed = 12;
    private const int MaxWave = 5;
    private const int ShotCooldownFrames = 7;

    private readonly List<GameEnemy> enemies = new();
    private readonly List<GameBullet> bullets = new();
    private readonly Random random = new();
    private ElementReference gameBoardElement;
    private CancellationTokenSource? gameLoopCancellation;
    private bool hasAccess;
    private bool shouldFocusBoard;
    private bool isMovingLeft;
    private bool isMovingRight;
    private bool isShooting;
    private double playerX;
    private double enemyDirection = 1;
    private int score;
    private int currentWave = 1;
    private int shotCooldownFrames;
    private GameState gameState = GameState.Ready;

    private string statusText => gameState switch {
        GameState.Ready => "Ready",
        GameState.Playing => "Playing",
        GameState.WaveClear => "Wave Clear",
        GameState.Win => "All Clear",
        GameState.GameOver => "Game Over",
        _ => "Ready"
    };

    protected override void OnInitialized() {
        hasAccess = FavoriteService.ConsumeSecretRouteAccess();

        if (!hasAccess) {
            NavigationManager.NavigateTo("not-found", replace: true);
            return;
        }

        ResetGame();
        shouldFocusBoard = true;
        gameLoopCancellation = new CancellationTokenSource();
        _ = RunGameLoopAsync(gameLoopCancellation.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!shouldFocusBoard) {
            return;
        }

        shouldFocusBoard = false;

        try {
            await gameBoardElement.FocusAsync();
        } catch (InvalidOperationException) {
        }
    }

    private async Task RunGameLoopAsync(CancellationToken cancellationToken) {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(33));

        try {
            while (await timer.WaitForNextTickAsync(cancellationToken)) {
                Tick();
                await InvokeAsync(StateHasChanged);
            }
        } catch (OperationCanceledException) {
        }
    }

    private void Tick() {
        if (gameState != GameState.Playing) {
            return;
        }

        MovePlayer();
        UpdateShooting();
        MoveBullets();
        MoveEnemies();
        ResolveCollisions();
        CheckGameState();
    }

    private void MovePlayer() {
        if (isMovingLeft == isMovingRight) {
            return;
        }

        playerX += isMovingLeft ? -PlayerSpeed : PlayerSpeed;
        playerX = Math.Clamp(playerX, 12, BoardWidth - PlayerWidth - 12);
    }

    private void UpdateShooting() {
        if (shotCooldownFrames > 0) {
            shotCooldownFrames--;
        }

        if (isShooting) {
            Shoot();
        }
    }

    private void MoveBullets() {
        for (var i = bullets.Count - 1; i >= 0; i--) {
            bullets[i].Y -= BulletSpeed;

            if (bullets[i].Y < -BulletHeight) {
                bullets.RemoveAt(i);
            }
        }
    }

    private void MoveEnemies() {
        if (enemies.Count == 0) {
            return;
        }

        var remainingPressure = Math.Max(0, GetEnemyCountForWave(currentWave) - enemies.Count);
        var speed = 1.55 + currentWave * 0.32 + remainingPressure * 0.045;
        var shouldDrop = enemies.Any(enemy =>
            enemy.X <= 14 && enemyDirection < 0 ||
            enemy.X >= BoardWidth - EnemySize - 14 && enemyDirection > 0);

        if (shouldDrop) {
            enemyDirection *= -1;

            foreach (var enemy in enemies) {
                enemy.Y += 16 + currentWave * 2;
            }
        }

        foreach (var enemy in enemies) {
            enemy.X += enemyDirection * speed;
        }
    }

    private void ResolveCollisions() {
        for (var bulletIndex = bullets.Count - 1; bulletIndex >= 0; bulletIndex--) {
            var bullet = bullets[bulletIndex];
            var hitIndex = enemies.FindIndex(enemy => IsHit(bullet, enemy));

            if (hitIndex < 0) {
                continue;
            }

            enemies.RemoveAt(hitIndex);
            bullets.RemoveAt(bulletIndex);
            score += 100 + currentWave * 20;
        }
    }

    private static bool IsHit(GameBullet bullet, GameEnemy enemy) {
        return bullet.X < enemy.X + EnemySize &&
               bullet.X + BulletWidth > enemy.X &&
               bullet.Y < enemy.Y + EnemySize &&
               bullet.Y + BulletHeight > enemy.Y;
    }

    private void CheckGameState() {
        if (enemies.Count == 0) {
            gameState = currentWave >= MaxWave ? GameState.Win : GameState.WaveClear;
            isMovingLeft = false;
            isMovingRight = false;
            isShooting = false;
            return;
        }

        if (enemies.Any(enemy => enemy.Y + EnemySize >= PlayerY - 8)) {
            gameState = GameState.GameOver;
            isMovingLeft = false;
            isMovingRight = false;
            isShooting = false;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e) {
        if (e.Key == " " || e.Key == "Spacebar") {
            if (gameState == GameState.WaveClear) {
                StartNextWave();
                return;
            }

            StartGame();
            isShooting = true;
            Shoot();
            return;
        }

        if (e.Key == "ArrowLeft") {
            isMovingLeft = true;
            StartGame();
            return;
        }

        if (e.Key == "ArrowRight") {
            isMovingRight = true;
            StartGame();
            return;
        }

        if (string.Equals(e.Key, "r", StringComparison.OrdinalIgnoreCase)) {
            ResetGame();
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e) {
        if (e.Key == "ArrowLeft") {
            isMovingLeft = false;
        } else if (e.Key == "ArrowRight") {
            isMovingRight = false;
        } else if (e.Key == " " || e.Key == "Spacebar") {
            isShooting = false;
        }
    }

    private void StartGame() {
        if (gameState == GameState.Ready) {
            gameState = GameState.Playing;
        }
    }

    private void Shoot() {
        if (gameState != GameState.Playing || bullets.Count >= 4 || shotCooldownFrames > 0) {
            return;
        }

        bullets.Add(new GameBullet {
            X = playerX + PlayerWidth / 2 - BulletWidth / 2,
            Y = PlayerY - BulletHeight
        });
        shotCooldownFrames = ShotCooldownFrames;
    }

    private void ResetGame() {
        bullets.Clear();
        currentWave = 1;
        score = 0;
        playerX = BoardWidth / 2 - PlayerWidth / 2;
        isMovingLeft = false;
        isMovingRight = false;
        isShooting = false;
        shotCooldownFrames = 0;
        SpawnWave(currentWave);
        gameState = GameState.Ready;
        shouldFocusBoard = true;
    }

    private void StartNextWave() {
        if (currentWave >= MaxWave) {
            return;
        }

        currentWave++;
        bullets.Clear();
        playerX = BoardWidth / 2 - PlayerWidth / 2;
        isMovingLeft = false;
        isMovingRight = false;
        isShooting = false;
        shotCooldownFrames = 0;
        SpawnWave(currentWave);
        gameState = GameState.Ready;
        shouldFocusBoard = true;
    }

    private void SpawnWave(int wave) {
        enemies.Clear();
        enemyDirection = random.Next(0, 2) == 0 ? -1 : 1;

        var count = GetEnemyCountForWave(wave);
        var columns = Math.Min(10, 6 + wave);
        var rows = (int)Math.Ceiling(count / (double)columns);
        var xSpacing = Math.Min(58, (BoardWidth - 120) / Math.Max(1, columns - 1));
        var ySpacing = Math.Max(34, 46 - wave * 2);
        var startX = (BoardWidth - (columns - 1) * xSpacing - EnemySize) / 2;
        var startY = 42;
        var spawned = 0;

        for (var row = 0; row < rows && spawned < count; row++) {
            var rowOffset = random.NextDouble() * 18 - 9;

            for (var col = 0; col < columns && spawned < count; col++) {
                var xJitter = random.NextDouble() * (10 + wave * 2) - (5 + wave);
                var yJitter = random.NextDouble() * (8 + wave * 2) - (4 + wave);
                var x = startX + col * xSpacing + xJitter + rowOffset;
                var y = startY + row * ySpacing + yJitter;

                enemies.Add(new GameEnemy {
                    X = Math.Clamp(x, 18, BoardWidth - EnemySize - 18),
                    Y = Math.Clamp(y, 32, 190)
                });

                spawned++;
            }
        }
    }

    private static int GetEnemyCountForWave(int wave) {
        return 14 + wave * 4;
    }

    private static string GetSpriteStyle(double x, double y) {
        return string.Create(CultureInfo.InvariantCulture, $"left: {x}px; top: {y}px;");
    }

    private string GetMessageTitle() {
        return gameState switch {
            GameState.WaveClear => $"Wave {currentWave} Clear",
            GameState.Win => "All Clear",
            GameState.GameOver => "Game Over",
            _ => "Hidden Invaders"
        };
    }

    private string GetMessageCopy() {
        return gameState switch {
            GameState.WaveClear => currentWave < MaxWave ? $"SpaceでWave {currentWave + 1}へ進む" : "Rで最初から",
            GameState.Win => "Rで最初から",
            GameState.GameOver => "Rでリスタート",
            _ => "Space長押しでショット / 矢印キーで開始"
        };
    }

    private string GetPrimaryControlHint() {
        return gameState switch {
            GameState.WaveClear => currentWave < MaxWave ? "Space Next Wave" : "All Clear",
            GameState.Win => "All Clear",
            _ => "Hold Space Shot"
        };
    }

    public void Dispose() {
        gameLoopCancellation?.Cancel();
        gameLoopCancellation?.Dispose();
    }

    private sealed class GameEnemy
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    private sealed class GameBullet
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    private enum GameState
    {
        Ready,
        Playing,
        WaveClear,
        Win,
        GameOver
    }
}
