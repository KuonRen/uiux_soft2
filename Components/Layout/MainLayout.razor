@inherits LayoutComponentBase
@implements IDisposable
@inject uiux_soft2.Services.FavoriteArticleService FavoriteService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="app-shell">
    <header class="site-header">
        <div class="site-header-inner">
            <a class="site-brand" href="" data-enhance-nav="false">
                <img class="site-brand-logo" src="images/osaka_icon.png" alt="UI/UX STUDY" />

                <span class="site-brand-text">
                    <span class="site-brand-title">大阪紹介</span>
                    <span class="site-brand-subtitle">Osaka Guide</span>
                </span>
            </a>

            <div class="site-header-actions">
                <button class="favorite-trigger"
                        type="button"
                        aria-haspopup="dialog"
                        aria-expanded="@isFavoriteModalOpen.ToString().ToLowerInvariant()"
                        @onclick="OpenFavoriteModal">
                    <span aria-hidden="true">☆</span>
                    <span>お気に入り</span>
                    <span class="favorite-count">@FavoriteService.Favorites.Count</span>
                </button>

            <button class="theme-toggle"
                    type="button"
                    data-theme-toggle
                    aria-label="テーマを切り替える"
                    aria-pressed="false"
                    onclick="window.appTheme.toggleTheme()">

                <span class="theme-toggle-label">Mode</span>

                <span class="theme-toggle-state" data-theme-label>
                    Light
                </span>
            </button>
            </div>
        </div>
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer">
        <div class="site-footer-inner">
            <p class="site-footer-title">
                UI/UX
            </p>

            <p class="site-footer-text">
                created by KuonRen
            </p>
        </div>
    </footer>

    @if (isFavoriteModalOpen) {
        <div class="favorite-modal-backdrop" @onclick="CloseFavoriteModal">
            <section class="favorite-modal @favoriteModalNudgeClass"
                     @ref="favoriteModalElement"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="favorite-modal-title"
                     tabindex="-1"
                     @onkeydown="HandleFavoriteModalKeyDown"
                     @onkeydown:stopPropagation="true"
                     @onclick:stopPropagation="true">
                <div class="favorite-modal-header">
                    <div>
                        <p class="favorite-modal-kicker">Favorite Articles</p>
                        <h2 id="favorite-modal-title">お気に入り一覧</h2>
                    </div>

                    <button class="favorite-modal-close"
                            type="button"
                            aria-label="お気に入り一覧を閉じる"
                            @onclick="CloseFavoriteModal">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="favorite-modal-body">
                    @if (FavoriteService.Favorites.Count == 0) {
                        <p class="favorite-empty">お気に入りはまだありません。</p>
                    } else {
                        <ul class="favorite-list">
                            @foreach (var favorite in FavoriteService.Favorites) {
                                <li>
                                    <div class="favorite-list-item">
                                        <a href="@($"article/{favorite.Id}")" @onclick="CloseFavoriteModal">
                                            <span class="favorite-topic">@favorite.TopicTitle</span>
                                            <span class="favorite-title">@favorite.Title</span>
                                        </a>

                                        <button class="favorite-remove"
                                                type="button"
                                                aria-label="@($"{favorite.Title}をお気に入りから削除")"
                                                @onclick="() => RemoveFavoriteAsync(favorite.Id)">
                                            削除
                                        </button>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </div>
    }
</div>

@code {
    private static readonly string[] FavoriteSecretCommand = [
        "ArrowUp",
        "ArrowUp",
        "ArrowDown",
        "ArrowDown",
        "ArrowLeft",
        "ArrowRight",
        "ArrowLeft",
        "ArrowRight",
        "B",
        "A"
    ];

    private bool isFavoriteModalOpen;
    private bool shouldFocusFavoriteModal;
    private ElementReference favoriteModalElement;
    private readonly List<string> favoriteCommandBuffer = new();
    private string? favoriteModalNudgeClass;

    protected override void OnInitialized() {
        FavoriteService.Changed += HandleFavoritesChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (shouldFocusFavoriteModal) {
            shouldFocusFavoriteModal = false;

            try {
                await JSRuntime.InvokeVoidAsync("window.appModal.setupFocusTrap", ".favorite-modal");
            } catch (JSException) {
            }
        }
    }

    private void OpenFavoriteModal() {
        isFavoriteModalOpen = true;
        shouldFocusFavoriteModal = true;
        favoriteCommandBuffer.Clear();
        favoriteModalNudgeClass = null;
        FavoriteService.SetFavoriteModalOpen(true);
    }

    private async Task CloseFavoriteModal() {
        isFavoriteModalOpen = false;
        shouldFocusFavoriteModal = false;
        favoriteCommandBuffer.Clear();
        favoriteModalNudgeClass = null;
        FavoriteService.SetFavoriteModalOpen(false);

        try {
            await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".favorite-modal");
        } catch (JSException) {
        }
    }

    private async Task RemoveFavoriteAsync(string articleId) {
        if (FavoriteService.RemoveFavorite(articleId)) {
            try {
                await JSRuntime.InvokeVoidAsync("window.appFavorites.set", FavoriteService.GetFavoriteIds());
            } catch (JSException) {
            }
        }
    }

    private async Task HandleFavoriteModalKeyDown(KeyboardEventArgs e) {
        if (!isFavoriteModalOpen) {
            return;
        }

        var key = NormalizeSecretCommandKey(e.Key);
        if (string.IsNullOrEmpty(key)) {
            return;
        }

        if (TryGetNudgeClass(key, out var nudgeClass)) {
            await NudgeFavoriteModalAsync(nudgeClass);
        }

        favoriteCommandBuffer.Add(key);

        while (!IsSecretCommandPrefix() && favoriteCommandBuffer.Count > 0) {
            favoriteCommandBuffer.RemoveAt(0);
        }

        if (favoriteCommandBuffer.Count == FavoriteSecretCommand.Length) {
            favoriteCommandBuffer.Clear();
            isFavoriteModalOpen = false;
            FavoriteService.SetFavoriteModalOpen(false);

            try {
                await JSRuntime.InvokeVoidAsync("window.appModal.removeFocusTrap", ".favorite-modal");
            } catch (JSException) {
            }

            FavoriteService.GrantSecretRouteAccess();
            NavigationManager.NavigateTo("5ecr3t");
        }
    }

    private static string NormalizeSecretCommandKey(string key) {
        if (key.Length == 1 && char.IsLetter(key[0])) {
            return key.ToUpperInvariant();
        }

        return key;
    }

    private static bool TryGetNudgeClass(string key, out string nudgeClass) {
        nudgeClass = key switch {
            "ArrowUp" => "is-nudging-up",
            "ArrowDown" => "is-nudging-down",
            "ArrowLeft" => "is-nudging-left",
            "ArrowRight" => "is-nudging-right",
            _ => string.Empty
        };

        return !string.IsNullOrEmpty(nudgeClass);
    }

    private async Task NudgeFavoriteModalAsync(string nudgeClass) {
        favoriteModalNudgeClass = null;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1);
        favoriteModalNudgeClass = nudgeClass;
    }

    private bool IsSecretCommandPrefix() {
        if (favoriteCommandBuffer.Count > FavoriteSecretCommand.Length) {
            return false;
        }

        for (var i = 0; i < favoriteCommandBuffer.Count; i++) {
            if (favoriteCommandBuffer[i] != FavoriteSecretCommand[i]) {
                return false;
            }
        }

        return true;
    }

    private void HandleFavoritesChanged() {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        FavoriteService.Changed -= HandleFavoritesChanged;
    }
}
