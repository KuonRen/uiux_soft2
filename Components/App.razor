<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <script>
            (() => {
                const storageKey = "uiux-theme";

                function normalizeTheme(theme) {
                    return theme === "dark" ? "dark" : "light";
                }

                function getSystemTheme() {
                    return window.matchMedia("(prefers-color-scheme: dark)").matches
                        ? "dark"
                        : "light";
                }

                function getStoredTheme() {
                    try {
                        return localStorage.getItem(storageKey);
                    } catch {
                        return null;
                    }
                }

                function saveTheme(theme) {
                    try {
                        localStorage.setItem(storageKey, theme);
                    } catch {
                        // localStorageが使えない環境では保存しない
                    }
                }

                function getTheme() {
                    const storedTheme = getStoredTheme();
                    const htmlTheme = document.documentElement.getAttribute("data-theme");
                    const theme = storedTheme || htmlTheme || getSystemTheme();

                    return normalizeTheme(theme);
                }

                function updateToggleLabel(theme) {
                    const labels = document.querySelectorAll("[data-theme-label]");
                    const buttons = document.querySelectorAll("[data-theme-toggle]");

                    labels.forEach((label) => {
                        label.textContent = theme === "dark" ? "Dark" : "Light";
                    });

                    buttons.forEach((button) => {
                        button.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
                    });
                }

                function applyTheme(theme) {
                    const normalizedTheme = normalizeTheme(theme);

                    document.documentElement.setAttribute("data-theme", normalizedTheme);
                    document.documentElement.style.colorScheme = normalizedTheme;

                    updateToggleLabel(normalizedTheme);

                    return normalizedTheme;
                }

                function setTheme(theme) {
                    const normalizedTheme = applyTheme(theme);

                    saveTheme(normalizedTheme);

                    return normalizedTheme;
                }

                function initTheme() {
                    const theme = getStoredTheme() || getSystemTheme();

                    applyTheme(theme);
                }

                function toggleTheme() {
                    const currentTheme = getTheme();
                    const nextTheme = currentTheme === "dark" ? "light" : "dark";

                    setTheme(nextTheme);
                }

                // CSS読み込み前に最初のテーマを反映する
                initTheme();

                window.appTheme = {
                    getTheme,
                    setTheme,
                    applyTheme,
                    initTheme,
                    toggleTheme
                };
            })();
    </script>

    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["uiux.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

    <body>
    <Routes />
    <ReconnectModal />

    <script src="@Assets["_framework/blazor.web.js"]"></script>

        <script>
        // 初期ロード後にテーマボタン表示を同期する
        window.appTheme.initTheme();

        // BlazorのEnhanced Navigation後に、戻されたテーマ属性を再適用する
        if (window.Blazor) {
            Blazor.addEventListener("enhancedload", () => {
                window.appTheme.initTheme();
            });
        }

        // 戻る・進む・BFCache復帰時にも再適用する
        window.addEventListener("pageshow", () => {
            window.appTheme.initTheme();
        });

        // モーダルのフォーカストラップ制御
        window.appModal = {
            setupFocusTrap: function (modalSelector) {
                const modal = document.querySelector(modalSelector);
                if (!modal) return;

                const focusableElements = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
                if (focusableElements.length === 0) return;

                const firstElement = focusableElements[0];
                const lastElement = focusableElements[focusableElements.length - 1];

                // 最初の要素（または閉じるボタン）にフォーカスを合わせる
                const closeBtn = modal.querySelector('.topic-modal-close');
                if (closeBtn) {
                    closeBtn.focus();
                } else {
                    firstElement.focus();
                }

                const handleKeyDown = function (e) {
                    if (e.key === 'Tab') {
                        if (e.shiftKey) { // Shift + Tab
                            if (document.activeElement === firstElement) {
                                lastElement.focus();
                                e.preventDefault();
                            }
                        } else { // Tab
                            if (document.activeElement === lastElement) {
                                firstElement.focus();
                                e.preventDefault();
                            }
                        }
                    }
                };

                modal._focusTrapListener = handleKeyDown;
                modal.addEventListener('keydown', handleKeyDown);
            },
            removeFocusTrap: function (modalSelector) {
                const modal = document.querySelector(modalSelector);
                if (modal && modal._focusTrapListener) {
                    modal.removeEventListener('keydown', modal._focusTrapListener);
                    delete modal._focusTrapListener;
                }
            }
        };
    </script>
</body>

</html>